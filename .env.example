# =============================================================================
# Hospital AI TeleAssist — Environment Configuration (example)
# Copy to `.env` and fill in real values. NEVER commit the real .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI (LLM reasoning, embeddings, and the Realtime voice API)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_KEY=sk-your-openai-api-key-here          # alias used by the Twilio agent
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# Requires access to the OpenAI Realtime API (gpt-realtime-2025-08-28)

# -----------------------------------------------------------------------------
# Anthropic / LangSmith (optional)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=

# -----------------------------------------------------------------------------
# Twilio (voice + SMS)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Service URLs / networking
# -----------------------------------------------------------------------------
PORT=5050
PUBLIC_URL=https://your-public-url.ngrok-free.app
HOSPITAL_ORCHESTRATOR_URL=http://localhost:8000
VOICE_SCHEDULER_URL=http://localhost:8001
HOSPITAL_API_TIMEOUT=30

# -----------------------------------------------------------------------------
# Databases / cache
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./hospital_ai.db
# Production example: postgresql://user:password@localhost:5432/hospital_ai
REDIS_URL=redis://localhost:6379
REDIS_TTL_HOURS=24
FAISS_INDEX_PATH=.faiss_index

# -----------------------------------------------------------------------------
# FHIR (healthcare interoperability)
# -----------------------------------------------------------------------------
USE_NATIVE_FHIR=false
FHIR_BASE_URL=

# -----------------------------------------------------------------------------
# Voice / Realtime tuning
# -----------------------------------------------------------------------------
VOICE=marin
AUDIO_FORMAT=g711_ulaw
VAD_THRESHOLD=0.65
VAD_SILENCE_DURATION_MS=1200
MAX_RESPONSE_TOKENS=500
VOICE_CALL_MAX_DURATION=1800

# -----------------------------------------------------------------------------
# Resilience / behavior
# -----------------------------------------------------------------------------
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=60
RETRY_MAX_ATTEMPTS=2
RETRY_BASE_DELAY=1.0
MAX_CONVERSATION_TURNS=50

# -----------------------------------------------------------------------------
# Safety / compliance
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-secret
ENABLE_PHI_REDACTION=true
ENABLE_EMERGENCY_DETECTION=true
ENABLE_CONVERSATION_LOGGING=true
ENABLE_METRICS_COLLECTION=true

# -----------------------------------------------------------------------------
# App / logging
# -----------------------------------------------------------------------------
HOSPITAL_NAME=City General Hospital
HOSPITAL_TIMEZONE=UTC
APPOINTMENT_DURATION_MINUTES=30
DEBUG=false
LOG_LEVEL=INFO
